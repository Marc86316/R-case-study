#!/usr/bin/env python
# coding: utf-8
# HW5 Q1 - NASA FD001 Turbine Engine RUL Prediction
# Feature Engineering: PCA vs Mutual Information
# Models: RF, XGB, SVR, DNN, GRU

# =============================================================================
# SECTION 1: Import Libraries
# =============================================================================
import random
import math
import numpy as np
import pandas as pd
import matplotlib.pyplot as plt

from sklearn.decomposition import PCA
from sklearn.feature_selection import mutual_info_regression
from sklearn.preprocessing import StandardScaler, MinMaxScaler
from sklearn.model_selection import GridSearchCV, RandomizedSearchCV, train_test_split
from sklearn.ensemble import RandomForestRegressor
from sklearn.svm import SVR
from sklearn import metrics
from sklearn.metrics import mean_absolute_error, mean_squared_error, mean_absolute_percentage_error
import xgboost as xgb
from skopt import BayesSearchCV

import tensorflow as tf
import keras
from keras import optimizers # 新版
from scikeras.wrappers import KerasRegressor # 新版
from tensorflow.keras.callbacks import EarlyStopping
from tensorflow.keras.models import Sequential
from tensorflow.keras.layers import Dense, Dropout, GRU, SimpleRNN, LSTM

import warnings
warnings.filterwarnings('ignore')

random.seed(516)
np.random.seed(1)
tf.random.set_seed(516)

# =============================================================================
# SECTION 2: Helper Functions
# =============================================================================
def calPerformance(y_true, y_pred):
    """計算 RMSE, MAE, MAPE 三項指標"""
    temp_list = []
    RMSE = math.sqrt(mean_squared_error(y_true, y_pred))
    temp_list.append(RMSE)
    MAE = mean_absolute_error(y_true, y_pred)
    temp_list.append(MAE)
    MAPE = mean_absolute_percentage_error(y_true, y_pred)
    temp_list.append(MAPE)
    return temp_list

def prediction_plot(y_true, y_pred, title='Prediction vs Actual'):
    """繪製預測值與實際值比較圖"""
    idx = range(len(y_true))
    plt.figure(figsize=(14, 5))
    plt.plot(idx, y_true, label='Actual', color='black')
    plt.plot(idx, y_pred, label='Predicted', color='red', alpha=0.7)
    plt.title(title)
    plt.xlabel('Sample')
    plt.ylabel('RUL')
    plt.legend()
    plt.tight_layout()
    plt.show()
    
# =============================================================================
# SECTION 3: Data Loading & Preprocessing
# =============================================================================

# --- 3.1 讀取 NASA FD001 資料 ---
# 直接讀 csv，欄位和 RUL 都已經準備好
df = pd.read_csv('Train.csv', index_col=0)  # index_col=0 處理第一欄的編號

# X 和 Y 直接分開
feature_cols = [col for col in df.columns if col != 'RUL']
df_x = df[feature_cols]
df_y = df['RUL']

# --- 3.2 計算 RUL（分段函數） ---
# RUL = 130           if cycle < 200（尚未損耗）
# RUL = 320 - cycle   if cycle >= 200（開始損耗）
# RUL最小值設為1避免MAPE分母趨近 0，造成MAPE爆炸 
df_y = df_y.clip(lower=1) # 加這行，

print("Feature shape:", df_x.shape)
print("Target shape:", df_y.shape)
print("\nRUL statistics:\n", df_y.describe())

# --- 3.3 Train/Test Split（隨機切分）---
train_X_raw, test_X_raw, train_y, test_y = train_test_split(
    df_x, df_y, test_size=0.2, random_state=516
)
train_X_raw = train_X_raw.reset_index(drop=True)
test_X_raw  = test_X_raw.reset_index(drop=True)
train_y     = train_y.reset_index(drop=True)
test_y      = test_y.reset_index(drop=True)

print(f"\nTrain size: {train_X_raw.shape}, Test size: {test_X_raw.shape}")

# =============================================================================
# SECTION 4: Feature Engineering
# =============================================================================

# ---- 4.1 共用標準化（StandardScaler）----
std_scaler = StandardScaler()
train_X_std = std_scaler.fit_transform(train_X_raw)
test_X_std  = std_scaler.transform(test_X_raw)

# ============================================================
# 方法一：PCA
# ============================================================
# 先用全部 15 個主成分觀察累積解釋變異
pca_full = PCA(n_components=15)
pca_full.fit(train_X_std)

cumvar = np.cumsum(pca_full.explained_variance_ratio_) * 100
print("\nPCA Cumulative Explained Variance (%):")
for i, v in enumerate(cumvar):
    print(f"  PC{i+1}: {v:.2f}%")

plt.figure(figsize=(8, 4))
plt.plot(range(1, 16), cumvar, marker='o')
plt.axhline(y=85, color='red', linestyle='--', label='85% threshold')
plt.xlabel('Number of Components')
plt.ylabel('Cumulative Explained Variance (%)')
plt.title('PCA - Cumulative Explained Variance')
plt.legend()
plt.tight_layout()
plt.show()

# 選擇能解釋 85% 變異的主成分數量（通常約 6~9 個，依實際結果調整）
n_components = int(np.argmax(cumvar >= 85) + 1)
print(f"\nSelected n_components (>=85% variance): {n_components}")

pca = PCA(n_components=n_components)
train_X_pca = pca.fit_transform(train_X_std)
test_X_pca  = pca.transform(test_X_std)

pca_cols = [f'pc{i+1}' for i in range(n_components)]
train_X_pca = pd.DataFrame(train_X_pca, columns=pca_cols)
test_X_pca  = pd.DataFrame(test_X_pca,  columns=pca_cols)

print("PCA train shape:", train_X_pca.shape)

# ============================================================
# 方法二：Mutual Information（互資訊）
# ============================================================
# MI 計算每個 sensor 與 RUL 之間的非線性統計相依程度，分數越高代表該特徵越能預測 RUL，直接保留原始特徵，可解釋性優於 PCA。
mi_scores = mutual_info_regression(train_X_std, train_y, random_state=516)
mi_df = pd.DataFrame({'Feature': feature_cols, 'MI_Score': mi_scores})
mi_df = mi_df.sort_values('MI_Score', ascending=False).reset_index(drop=True)
print(mi_df)
# 畫出長條圖更直觀
mi_df.plot(kind='bar', x='Feature', y='MI_Score', figsize=(10,4))
plt.title('Mutual Information Scores')
plt.tight_layout()
plt.show()

# 依 mi_df 結果，最後一筆資料sensor6分數明顯落差至接近0，故排除此特徵
top_features = mi_df[mi_df['MI_Score'] > 0.02]['Feature'].tolist()
print(top_features)

# MinMaxScaler for MI features（與 PCA 使用 StandardScaler 不同，
# 這裡示範另一種常見做法；兩者皆可，保持一致即可）
mm_scaler = MinMaxScaler()
train_X_mi = pd.DataFrame(
    mm_scaler.fit_transform(train_X_raw[top_features]),
    columns=top_features
)
test_X_mi = pd.DataFrame(
    mm_scaler.transform(test_X_raw[top_features]),
    columns=top_features
)

print("MI train shape:", train_X_mi.shape)

# =============================================================================
# SECTION 5: Model Training & Evaluation
# =============================================================================
# 用一個 feature_sets 字典管理兩種特徵工程的資料，這樣一個迴圈就能同時跑兩種特徵工程，避免重複寫兩份相同邏輯。

feature_sets = {
    'PCA': (train_X_pca, test_X_pca),
    'MI':  (train_X_mi,  test_X_mi)
}

# 儲存所有結果
all_results = {}   # {feat_method: {model_name: [train_perf, test_perf]}}

# =============================================================================
# SECTION 5.1: RF（隨機森林迴歸）
# =============================================================================
for feat_name, (tr_X, ts_X) in feature_sets.items():

    rf_param_grid = {
        'n_estimators': [80, 120, 150],  # 森林裡有幾棵樹
        'max_depth':    [4, 6, 8],       # 每棵樹最多長幾層
        'max_features': [3, 5, 7],       # 每次分裂時隨機考慮幾個特徵
        'min_samples_split': [20, 40]    # 一個節點至少要有幾筆資料才能再分裂
    }
    # 調參
    grid_rf = GridSearchCV(
        RandomForestRegressor(random_state=516),
        param_grid=rf_param_grid, cv=3, n_jobs=-1 #cv=3 的意思是：把 train 資料切成 3 份，輪流用其中 2 份訓練、1 份驗證，每種參數組合都跑 3 次取平均，找出表現最好的參數組合。
    )
    grid_rf.fit(tr_X, train_y)
    print(f"\n[RF | {feat_name}] Best params: {grid_rf.best_params_}")
    # 用最佳參數建模
    RF = RandomForestRegressor(
        n_estimators    = grid_rf.best_params_['n_estimators'],  #grid_rf.best_params_ 會自動取出 54 種組合中表現最好的那一組參數，用這組參數重新建立一個乾淨的模型並訓練。
        max_depth       = grid_rf.best_params_['max_depth'],
        max_features    = grid_rf.best_params_['max_features'],
        min_samples_split = grid_rf.best_params_['min_samples_split'],
        random_state=516
    )
    RF.fit(tr_X, train_y)
    
    # 預測
    RF_tr = RF.predict(tr_X)
    RF_ts = RF.predict(ts_X)
    # 計算績效    
    train_RF = calPerformance(train_y, RF_tr)
    test_RF  = calPerformance(test_y,  RF_ts)
    # 存入結果字典
    all_results.setdefault(feat_name, {})['RF'] = [train_RF, test_RF]

    print(f"  Train RMSE={train_RF[0]:.4f}  MAE={train_RF[1]:.4f}  MAPE={train_RF[2]:.4f}")
    print(f"  Test  RMSE={test_RF[0]:.4f}  MAE={test_RF[1]:.4f}  MAPE={test_RF[2]:.4f}")

# =============================================================================
# SECTION 5.2: XGB（梯度提升迴歸）
# =============================================================================
for feat_name, (tr_X, ts_X) in feature_sets.items():

    xgb_param_grid = {
        'n_estimators':     [80, 120, 150],   # 總共建幾棵樹
        'max_depth':        [4, 6, 8],        # 每棵樹最多長幾層
        'learning_rate':    [0.01, 0.05, 0.1],# 每棵樹的學習步伐大小
        'colsample_bytree': [0.5, 0.7, 0.9]  # 每棵樹隨機使用幾%的特徵
    }
    # 調參
    grid_xgb = GridSearchCV(
        xgb.XGBRegressor(random_state=516, verbosity=0),
        param_grid=xgb_param_grid, cv=3, n_jobs=-1
    )
    grid_xgb.fit(tr_X, train_y)
    print(f"\n[XGB | {feat_name}] Best params: {grid_xgb.best_params_}")
    # 用最佳參數建模
    XGB = xgb.XGBRegressor(
        n_estimators     = grid_xgb.best_params_['n_estimators'],
        max_depth        = grid_xgb.best_params_['max_depth'],
        learning_rate    = grid_xgb.best_params_['learning_rate'],
        colsample_bytree = grid_xgb.best_params_['colsample_bytree'],
        random_state=516, verbosity=0
    )
    XGB.fit(tr_X, train_y)
    
    # 預測
    XGB_tr = XGB.predict(tr_X)
    XGB_ts = XGB.predict(ts_X)
    # 計算績效
    train_XGB = calPerformance(train_y, XGB_tr)
    test_XGB  = calPerformance(test_y,  XGB_ts)
    # 存入結果字典
    all_results.setdefault(feat_name, {})['XGB'] = [train_XGB, test_XGB]
    
    print(f"  Train RMSE={train_XGB[0]:.4f}  MAE={train_XGB[1]:.4f}  MAPE={train_XGB[2]:.4f}")
    print(f"  Test  RMSE={test_XGB[0]:.4f}  MAE={test_XGB[1]:.4f}  MAPE={test_XGB[2]:.4f}")

# =============================================================================
# SECTION 5.3: SVR（支持向量迴歸）
# =============================================================================
for feat_name, (tr_X, ts_X) in feature_sets.items():

    np.random.seed(0)  # 固定隨機種子，讓每次產生的候選參數一樣
    params_SVR = {
        'C':       np.random.uniform(10, 100, 8),   # 從 10~100 隨機產生 8 個候選值
        'gamma':   np.random.uniform(0.01, 10, 8),  # 從 0.01~10 隨機產生 8 個候選值
        'epsilon': np.random.uniform(0.05, 0.3, 8), # 從 0.05~0.3 隨機產生 8 個候選值
        'kernel':  ['rbf']   # 固定使用 rbf 高斯核函數，適合處理非線性關係，是 SVR 最常用的核函數。
    }
    svr_cv = RandomizedSearchCV(
        SVR(), params_SVR, cv=3, random_state=516, n_iter=10, n_jobs=-1  # 只隨機試 10 組參數組合
    )
    svr_cv.fit(tr_X, train_y)
    print(f"\n[SVR | {feat_name}] Best params: {svr_cv.best_params_}")

    SVR_model = svr_cv.best_estimator_   #直接用 best_estimator_ 取出已經訓練好的最佳模型
    # 預測
    SVR_tr = SVR_model.predict(tr_X)
    SVR_ts = SVR_model.predict(ts_X)
    # 計算績效
    train_SVR = calPerformance(train_y, SVR_tr)
    test_SVR  = calPerformance(test_y,  SVR_ts)
    # 存入結果字典
    all_results.setdefault(feat_name, {})['SVR'] = [train_SVR, test_SVR]

    print(f"  Train RMSE={train_SVR[0]:.4f}  MAE={train_SVR[1]:.4f}  MAPE={train_SVR[2]:.4f}")
    print(f"  Test  RMSE={test_SVR[0]:.4f}  MAE={test_SVR[1]:.4f}  MAPE={test_SVR[2]:.4f}")

# =============================================================================
# SECTION 5.4: DNN（深度神經網路）
# =============================================================================
es = EarlyStopping(monitor='val_loss', mode='min', patience=20, verbose=0)

def build_DNN(train_input_dim, first_hidden_neuron, n_dropout, n_hidden,
              n_neurons, learning_rate, activation, kernel_initializer,
              n_epochs, n_batch_size, **kwargs):
    model = Sequential()
    model.add(Dense(first_hidden_neuron, input_dim=train_input_dim,
                    activation=activation, kernel_initializer=kernel_initializer))
    for _ in range(n_hidden):
        model.add(Dense(n_neurons, activation=activation,
                        kernel_initializer=kernel_initializer))
        model.add(Dropout(n_dropout))
    model.add(Dense(1, activation='linear'))
    optimizer = optimizers.Adam(learning_rate=learning_rate)
    model.compile(loss='mean_squared_error', optimizer=optimizer)
    return model

for feat_name, (tr_X, ts_X) in feature_sets.items():

    tr_arr = np.array(tr_X)
    ts_arr = np.array(ts_X)
    input_dim = tr_arr.shape[1]

    # 包裝成 KerasRegressor 以便做 RandomizedSearchCV
    def make_DNN(**kw):
        return build_DNN(input_dim, **kw)

    keras_reg = KerasRegressor(
        model=make_DNN,
        first_hidden_neuron=8,
        n_dropout=0.1,
        n_hidden=2,
        n_neurons=8,
        learning_rate=0.01,
        activation='relu',
        kernel_initializer='glorot_uniform',
        n_epochs=200,
        n_batch_size=32
    )

    params_DNN = {
        'first_hidden_neuron': [8, 16],
        'n_dropout':           [0.1, 0.25],
        'n_hidden':            [2, 3],
        'n_neurons':           [8, 16],
        'learning_rate':       [0.01, 0.02],
        'activation':          ['relu', 'elu'],
        'kernel_initializer':  ['glorot_uniform', 'lecun_normal'],
        'n_epochs':            [200],
        'n_batch_size':        [32, 64],        
    }

    RS_dnn = RandomizedSearchCV(keras_reg, params_DNN, n_iter=10, cv=3,
                                random_state=516)
    RS_dnn.fit(tr_arr, train_y,
               validation_split=0.2, callbacks=[es])
    print(f"\n[DNN | {feat_name}] Best params: {RS_dnn.best_params_}")

    DNN = RS_dnn.best_estimator_
    DNN_tr = DNN.predict(tr_arr)
    DNN_ts = DNN.predict(ts_arr)
    train_DNN = calPerformance(train_y, DNN_tr)
    test_DNN  = calPerformance(test_y,  DNN_ts)

    all_results.setdefault(feat_name, {})['DNN'] = [train_DNN, test_DNN]

    print(f"  Train RMSE={train_DNN[0]:.4f}  MAE={train_DNN[1]:.4f}  MAPE={train_DNN[2]:.4f}")
    print(f"  Test  RMSE={test_DNN[0]:.4f}  MAE={test_DNN[1]:.4f}  MAPE={test_DNN[2]:.4f}")

# =============================================================================
# SECTION 5.5: GRU（門控循環單元）
# =============================================================================
# GRU 需要 3D 輸入：(samples, timesteps, features)
# 此處 timestep=1，表示每個樣本視為獨立時間點
def build_GRU(train_input_dim,  # 特徵數量（PCA=5，MI=14）
              n_dropout,         # Dropout 比例
              n_hidden,          # GRU 總層數
              n_neurons1,        # 第一層 GRU 的神經元數
              n_neurons2,        # 第二層 GRU 的神經元數
              last_n_neurons,    # 最後一層 GRU 的神經元數
              learning_rate,     # 學習率
              activation,        # 激活函數
              n_epochs,          # 最多訓練幾輪
              n_batch_size, **kwargs):      # 批次大小             

    model = Sequential()
    # 多層 GRU：前面幾層需 return_sequences=True
    for i in range(n_hidden - 1):
        units = n_neurons1 if i == 0 else n_neurons2
        model.add(GRU(units=units,
                      input_shape=(1, train_input_dim),
                      activation=activation,
                      return_sequences=True)) #return_sequences=True 是關鍵設定，意思是這層 GRU 把每個時間步的輸出都傳給下一層，這樣下一層 GRU 才能繼續處理序列資料。
    # 最後一層 GRU：return_sequences=False
    model.add(GRU(units=last_n_neurons,
                  input_shape=(1, train_input_dim),
                  activation=activation,
                  return_sequences=False))  #只輸出最後一個時間步，表示這層只輸出"最後一個時間步的結果"，把序列資訊壓縮成一個向量，再傳給後面的 Dense 輸出層。
    model.add(Dropout(n_dropout))
    model.add(Dense(1, activation='linear'))

    optimizer = optimizers.Adam(learning_rate=learning_rate)  # 固定用 Adam
    model.compile(loss='mean_absolute_percentage_error', optimizer=optimizer)
    return model

for feat_name, (tr_X, ts_X) in feature_sets.items():

    tr_arr = np.array(tr_X)  # 先轉成 numpy array（2D）
    ts_arr = np.array(ts_X)
    input_dim = tr_arr.shape[1]  # 記錄特徵數
    
    # reshape  2D 為 3D
    tr_3d = tr_arr.reshape((tr_arr.shape[0], 1, tr_arr.shape[1]))
    ts_3d = ts_arr.reshape((ts_arr.shape[0], 1, ts_arr.shape[1]))

    train_y_3d = train_y.values.reshape(-1, 1)
    test_y_3d  = test_y.values.reshape(-1, 1)

    def make_GRU(**kw):
        return build_GRU(input_dim, **kw)

    keras_gru = KerasRegressor(
        model=make_GRU,
        n_dropout=0.05,
        n_hidden=2,
        n_neurons1=32,
        n_neurons2=32,
        last_n_neurons=16,
        learning_rate=0.01,
        activation='relu',
        n_epochs=200,
        n_batch_size=32
    )

    # 固定使用 Adam，從 params 中移除 select_optimizer
    params_GRU = {
        'n_dropout':     [0.05, 0.1],
        'n_hidden':      [2, 3],
        'n_neurons1':    [32, 64],
        'n_neurons2':    [32, 64],
        'last_n_neurons':[16, 32],
        'learning_rate': [0.01, 0.03],
        'activation':    ['relu', 'tanh'],
        'n_epochs':      [200],
        'n_batch_size':  [32, 64]
        # select_optimizer 移除，改在 build_GRU 函數中固定
    }

    BS_gru = BayesSearchCV(keras_gru, params_GRU, n_iter=10, cv=3,
                           random_state=516)
    BS_gru.fit(tr_3d, train_y_3d,
               validation_split=0.2, callbacks=[es])
    print(f"\n[GRU | {feat_name}] Best params: {BS_gru.best_params_}")

    GRU_model = BS_gru.best_estimator_
    GRU_tr = GRU_model.predict(tr_3d)
    GRU_ts = GRU_model.predict(ts_3d)
    train_GRU = calPerformance(train_y_3d, GRU_tr)
    test_GRU  = calPerformance(test_y_3d,  GRU_ts)

    all_results.setdefault(feat_name, {})['GRU'] = [train_GRU, test_GRU]

    print(f"  Train RMSE={train_GRU[0]:.4f}  MAE={train_GRU[1]:.4f}  MAPE={train_GRU[2]:.4f}")
    print(f"  Test  RMSE={test_GRU[0]:.4f}  MAE={test_GRU[1]:.4f}  MAPE={test_GRU[2]:.4f}")    

# =============================================================================
# SECTION 6: Summary Table
# =============================================================================
model_names = ['RF', 'XGB', 'SVR', 'DNN', 'GRU']
metrics_names = ['RMSE', 'MAE', 'MAPE']

for feat_name in ['PCA', 'MI']:
    for split in ['train', 'test']:
        idx = 0 if split == 'train' else 1
        tab = pd.DataFrame(index=metrics_names)
        for m in model_names:
            tab[m] = all_results[feat_name][m][idx]
        print(f"\n{'='*55}")
        print(f"  [{feat_name}] {split.upper()} Performance")
        print(f"{'='*55}")
        print(round(tab, 4))

# --- 找出最佳組合（以 Test RMSE 為主要排序依據）---
records = []
for feat_name in ['PCA', 'MI']:
    for m in model_names:
        test_perf = all_results[feat_name][m][1]
        records.append({
            'Feature': feat_name,
            'Model':   m,
            'Test_RMSE': test_perf[0],
            'Test_MAE':  test_perf[1],
            'Test_MAPE': test_perf[2]
        })

summary = pd.DataFrame(records).sort_values('Test_RMSE').reset_index(drop=True)
print("\n" + "="*55)
print("  Overall Ranking (sorted by Test RMSE)")
print("="*55)
print(round(summary, 4))
print(f"\n>>> Best combination: {summary.iloc[0]['Feature']} + {summary.iloc[0]['Model']}")

# =============================================================================
# SECTION 7: 視覺化結果
# =============================================================================
import matplotlib.pyplot as plt
import numpy as np

model_names = ['RF', 'XGB', 'SVR', 'DNN', 'GRU']
metrics_names = ['RMSE', 'MAE', 'MAPE']
colors_pca = ['#2196F3', '#4CAF50', '#FF9800', '#9C27B0', '#F44336']
colors_mi  = ['#1565C0', '#2E7D32', '#E65100', '#6A1B9A', '#B71C1C']

# -------------------------------------------------------
# 圖一：Test RMSE 長條圖比較（PCA vs MI）
# -------------------------------------------------------
fig, ax = plt.subplots(figsize=(12, 5))

x = np.arange(len(model_names))
width = 0.35

rmse_pca = [all_results['PCA'][m][1][0] for m in model_names]
rmse_mi  = [all_results['MI'][m][1][0]  for m in model_names]

bars1 = ax.bar(x - width/2, rmse_pca, width, label='PCA', color='#2196F3', alpha=0.85)
bars2 = ax.bar(x + width/2, rmse_mi,  width, label='MI',  color='#FF9800', alpha=0.85)

# 在每個長條上方顯示數值
for bar in bars1:
    ax.text(bar.get_x() + bar.get_width()/2, bar.get_height() + 0.2,
            f'{bar.get_height():.2f}', ha='center', va='bottom', fontsize=9)
for bar in bars2:
    ax.text(bar.get_x() + bar.get_width()/2, bar.get_height() + 0.2,
            f'{bar.get_height():.2f}', ha='center', va='bottom', fontsize=9)

ax.set_xlabel('Model', fontsize=12)
ax.set_ylabel('Test RMSE', fontsize=12)
ax.set_title('Test RMSE Comparison: PCA vs MI', fontsize=14, fontweight='bold')
ax.set_xticks(x)
ax.set_xticklabels(model_names)
ax.legend()
ax.grid(axis='y', alpha=0.3)
plt.tight_layout()
plt.show()

# -------------------------------------------------------
# 圖二：Train vs Test RMSE（過擬合檢查）
# 綠色是 Train RMSE、紅色是 Test RMSE，兩者差距越大代表過擬合越嚴重
# -------------------------------------------------------
fig, axes = plt.subplots(1, 2, figsize=(14, 5))

for ax, feat_name in zip(axes, ['PCA', 'MI']):
    train_rmse = [all_results[feat_name][m][0][0] for m in model_names]
    test_rmse  = [all_results[feat_name][m][1][0] for m in model_names]

    x = np.arange(len(model_names))
    width = 0.35

    ax.bar(x - width/2, train_rmse, width, label='Train RMSE',
           color='#4CAF50', alpha=0.85)
    ax.bar(x + width/2, test_rmse,  width, label='Test RMSE',
           color='#F44336', alpha=0.85)

    ax.set_title(f'{feat_name} - Train vs Test RMSE', fontsize=13, fontweight='bold')
    ax.set_xticks(x)
    ax.set_xticklabels(model_names)
    ax.set_ylabel('RMSE')
    ax.legend()
    ax.grid(axis='y', alpha=0.3)

plt.suptitle('Overfitting Check', fontsize=14, fontweight='bold', y=1.02)
plt.tight_layout()
plt.show()

# -------------------------------------------------------
# 圖三：三個指標的 Heatmap
# 用顏色深淺同時展示 RMSE、MAE、MAPE 三個指標，顏色越深（紅色）代表誤差越大，越淺（綠色）代表越好
# -------------------------------------------------------
fig, axes = plt.subplots(1, 2, figsize=(14, 4))

for ax, feat_name in zip(axes, ['PCA', 'MI']):
    data = []
    for m in model_names:
        data.append(all_results[feat_name][m][1])  # test 績效

    data = np.array(data).T  # shape: (3 metrics, 5 models)

    im = ax.imshow(data, cmap='RdYlGn_r', aspect='auto')

    ax.set_xticks(range(len(model_names)))
    ax.set_xticklabels(model_names)
    ax.set_yticks(range(len(metrics_names)))
    ax.set_yticklabels(metrics_names)
    ax.set_title(f'{feat_name} - Test Performance Heatmap',
                 fontsize=13, fontweight='bold')

    # 在格子內顯示數值
    for i in range(len(metrics_names)):
        for j in range(len(model_names)):
            ax.text(j, i, f'{data[i, j]:.3f}',
                    ha='center', va='center', fontsize=10,
                    color='black')

    plt.colorbar(im, ax=ax)

plt.tight_layout()
plt.show()

# -------------------------------------------------------
# 圖四：最終排名圓點圖
# 金銀銅牌顏色標示前三名，橫向排列讓排名一目瞭然
# -------------------------------------------------------
summary_sorted = summary.reset_index(drop=True)
labels = [f"{row['Feature']}+{row['Model']}" 
          for _, row in summary_sorted.iterrows()]

fig, ax = plt.subplots(figsize=(10, 5))
colors = ['gold' if i == 0 else 'silver' if i == 1 else 
          '#CD7F32' if i == 2 else '#90CAF9' 
          for i in range(len(labels))]

bars = ax.barh(labels[::-1], summary_sorted['Test_RMSE'][::-1],
               color=colors[::-1], alpha=0.9, edgecolor='white')

for bar, val in zip(bars, summary_sorted['Test_RMSE'][::-1]):
    ax.text(bar.get_width() + 0.1, bar.get_y() + bar.get_height()/2,
            f'{val:.4f}', va='center', fontsize=10)

ax.set_xlabel('Test RMSE', fontsize=12)
ax.set_title('Overall Ranking by Test RMSE', fontsize=14, fontweight='bold')
ax.grid(axis='x', alpha=0.3)
plt.tight_layout()
plt.show()
